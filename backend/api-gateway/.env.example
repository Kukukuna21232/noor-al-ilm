# ═══════════════════════════════════════════════════════════
# NOOR AL-ILM v2.0 — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://noor-al-ilm.com
ALLOWED_ORIGINS=https://noor-al-ilm.com,https://www.noor-al-ilm.com

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noor_al_ilm
DB_USER=postgres
DB_PASSWORD=your_strong_db_password
DB_SSL=false
DB_POOL_MAX=30

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_very_long_random_jwt_secret_minimum_64_characters_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_also_minimum_64_characters
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ── Storage ───────────────────────────────────────────────
# Options: local | s3 | r2
STORAGE_PROVIDER=local

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=noor-al-ilm-media

# Cloudflare R2 (set STORAGE_PROVIDER=r2)
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true

# CDN
CDN_BASE_URL=https://cdn.noor-al-ilm.com

# ── AI / OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://noor-al-ilm.com/api/auth/google/callback

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=500

# ── Upload ────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=2048

# ── RTMP Live Streaming ───────────────────────────────────
RTMP_SERVER_URL=rtmp://localhost:1935

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@noor-al-ilm.com
ADMIN_PASSWORD=Admin@NoorIlm2024

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ── Elasticsearch ─────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password

# ── Payment Processing ───────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Analytics & Monitoring ───────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

# ── Cache Configuration ───────────────────────────────────
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_STRATEGY=redis

# ── Session Management ───────────────────────────────────
SESSION_SECRET=your_session_secret_key_minimum_32_characters
SESSION_MAX_AGE=86400000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict

# ── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_MAX_AGE=86400
HELMET_ENABLED=true

# ── WebSocket Configuration ───────────────────────────────
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_LIMIT=1024

# ── File Upload Configuration ─────────────────────────────
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=5
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt,mp4,mp3,wav
UPLOAD_TEMP_DIR=/tmp/uploads

# ── Backup Configuration ─────────────────────────────────
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=noor-al-ilm-backups
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key

# ── SSL/TLS Configuration ─────────────────────────────────
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem
SSL_CA_PATH=/path/to/ssl/ca.pem

# ── API Configuration ─────────────────────────────────────
API_VERSION=v1
API_TIMEOUT=30000
API_REQUEST_LIMIT=1000
API_RESPONSE_COMPRESSION=true

# ── Feature Flags ─────────────────────────────────────────
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_LIVE_STREAMING=true
ENABLE_AI_FEATURES=true
ENABLE_FORUM=true
ENABLE_COURSES=true
ENABLE_QURAN_FEATURES=true
ENABLE_PRAYER_TIMES=true

# ── Localization ───────────────────────────────────────────
DEFAULT_LANGUAGE=ar
SUPPORTED_LANGUAGES=ar,ru,en,es,fr,de,tr,ur,bn,id,ms,ha,sw,zh,hi
ENABLE_AUTO_TRANSLATION=false
TRANSLATION_API_KEY=your_translation_api_key

# ── Islamic Content APIs ───────────────────────────────────
QURAN_API_URL=https://api.alquran.cloud/v1
PRAYER_TIMES_API_URL=https://api.aladhan.com/v1
HADITH_API_URL=https://api.sunnah.com/v1
ISLAMIC_CALENDAR_API_URL=https://api.aladhan.com/v1/hijriCalendar

# ── Performance Optimization ─────────────────────────────
ENABLE_CACHING=true
ENABLE_COMPRESSION=true
ENABLE_GZIP=true
ENABLE_BROTLI=true
STATIC_ASSET_CACHE_TTL=31536000

# ── Development Settings ─────────────────────────────────
DEBUG_MODE=false
ENABLE_API_DOCS=true
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true
MOCK_EXTERNAL_APIS=false

# ── Production Settings ─────────────────────────────────
CLUSTER_MODE=true
CLUSTER_WORKERS=0
ENABLE_PM2=true
PM2_INSTANCES=max
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=30000

# ── Monitoring & Alerting ───────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_HEALTH_ENDPOINT=true
HEALTH_ENDPOINT_PATH=/health
ENABLE_READINESS_ENDPOINT=true
READINESS_ENDPOINT_PATH=/ready

# ── Database Optimization ───────────────────────────────
DB_CONNECTION_TIMEOUT=30000
DB_QUERY_TIMEOUT=10000
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000

# ── Content Delivery ─────────────────────────────────────
CDN_ENABLED=true
CDN_CACHE_TTL=3600
CDN_BYPASS_TOKEN=your_cdn_bypass_token
STATIC_ASSET_VERSIONING=true

# ── Error Handling ───────────────────────────────────────
ERROR_REPORTING_ENABLED=true
ERROR_REPORTING_WEBHOOK=https://your-error-webhook-url
ERROR_LOG_RETENTION_DAYS=30
CRITICAL_ERROR_ALERTS=true

# ── Notification System ─────────────────────────────────
PUSH_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=false
NOTIFICATION_QUEUE_REDIS=true
