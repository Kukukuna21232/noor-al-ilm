# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CDN_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/noor_ilm
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=noor_ilm
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# External Services
OPENAI_API_KEY=your-openai-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Payment Services
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email Services
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@noor-al-ilm.com

# Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=noor-al-ilm-uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# Search & Indexing
ELASTICSEARCH_URL=http://localhost:9200
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_ADMIN_API_KEY=your-algolia-admin-key
ALGOLIA_SEARCH_API_KEY=your-algolia-search-key

# Social Media Integration
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Development & Testing
NODE_ENV=development
PORT=3000
API_PORT=5000
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
ENABLE_SENTRY=false

# Production Overrides (uncomment for production)
# NODE_ENV=production
# ENABLE_LOGGING=true
# ENABLE_ANALYTICS=true
# ENABLE_SENTRY=true
# NEXT_PUBLIC_APP_URL=https://noor-al-ilm.com
# NEXT_PUBLIC_API_URL=https://api.noor-al-ilm.com
# NEXT_PUBLIC_CDN_URL=https://cdn.noor-al-ilm.com
# NEXT_PUBLIC_WS_URL=wss://api.noor-al-ilm.com

# SSL Configuration (for production)
# SSL_CERT_PATH=/path/to/ssl/cert.pem
# SSL_KEY_PATH=/path/to/ssl/key.pem

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=5
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_LIVE_STREAMING=true
ENABLE_AI_FEATURES=true
ENABLE_FORUM=true
ENABLE_COURSES=true

# Localization
DEFAULT_LANGUAGE=ar
SUPPORTED_LANGUAGES=ar,ru,en,es,fr,de,tr,ur,bn,id,ms,ha,sw,zh,hi
ENABLE_AUTO_TRANSLATION=false

# Islamic Content
QURAN_API_URL=https://api.alquran.cloud/v1
PRAYER_TIMES_API_URL=https://api.aladhan.com/v1
HADITH_API_URL=https://api.sunnah.com/v1

# CDN Configuration
CDN_BASE_URL=https://cdn.noor-al-ilm.com
STATIC_ASSET_URL=https://assets.noor-al-ilm.com
MEDIA_ASSET_URL=https://media.noor-al-ilm.com

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=noor-al-ilm-backups

# Monitoring & Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_COLLECTION_INTERVAL=60000
PERFORMANCE_MONITORING=true

# Security
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true
BCRYPT_ROUNDS=12
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_LIMIT=1024
